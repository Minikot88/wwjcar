VITE_APP_NAME=WWJ Car Rent

# Temporary subdomain deployment.
# Replace these with the actual temporary host before building.
VITE_SITE_URL=https://wwjcar.example.com
VITE_CANONICAL_URL=https://wwjcar.example.com

# Use same-origin API proxy through Nginx Proxy Manager when possible.
VITE_API_BASE_URL=/api

VITE_PORT=5180

# Leave blank until real services are connected.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_GA_MEASUREMENT_ID=
VITE_GTM_CONTAINER_ID=
VITE_GOOGLE_BUSINESS_PROFILE_URL=
VITE_GOOGLE_MAPS_URL=

VITE_ENFORCE_HTTPS=true
VITE_REDIRECT_WWW=false
